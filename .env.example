# ═══════════════════════════════════════════════════════════════════
# TOURKIA — Ortam Değişkenleri Şablonu
# Bu dosyayı .env.local olarak kopyalayın ve gerçek değerleri girin.
# .env.local asla Git'e yüklenmez (gitignore'da).
# ═══════════════════════════════════════════════════════════════════

# ── API ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── PAYMENT-WEBHOOK-ARMOR: Gizli İmza Anahtarları ──────────────────
# Stripe Dashboard → Webhooks → İlgili endpoint → Signing Secret
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# İyzico Merchant Panel → Webhook ayarları → Secret Key
IYZICO_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PayTR Merchant Panel → API Bilgileri
PAYTR_MERCHANT_KEY=XXXXXXXXXXXXXXXXXXXX
PAYTR_MERCHANT_SALT=XXXXXXXXXXXXXXXXXXXX

# ── ADMIN ALERT ─────────────────────────────────────────────────────
# Fraud tespitinde alarm gönderilecek yönetici e-postası
ADMIN_ALERT_EMAIL=admin@tourkia.com
# Admin webhook log API'sine erişim tokeni
ADMIN_WEBHOOK_TOKEN=tourkia_admin_secret_change_this_in_production

# ── DISASTER-RECOVERY-PROTOCOL: Otomatik Şifreli Yedekleme ─────────────
# Fernet AES-256 Şifreleme Anahtarı — Üretmek için:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BACKUP_ENCRYPTION_KEY=your_fernet_key_here_CHANGE_THIS

# AWS S3 Kimlik Bilgileri (Ana sunucudan FARKLI hesap — izolasyon şart!)
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=eu-central-1
BACKUP_S3_BUCKET=tourkia-backups-dr

# ── LOAD TEST / INTERNAL ─────────────────────────────────────────────────
INTERNAL_AUDIT_KEY=tourkia_audit_internal_change_this

# ── GOOGLE ANALYTICS ────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

